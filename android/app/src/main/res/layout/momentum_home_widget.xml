<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@drawable/widget_background">

    <!-- ── Header row ──────────────────────────────────────────────────── -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="4dp">

        <!-- Blue checkmark accent -->
        <TextView android:layout_width="22dp" android:layout_height="22dp" android:text="✓" android:textColor="#4A90E2" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="8dp"/>

        <!-- Team name — tapping opens team selector in app -->
        <TextView android:id="@+id/widget_team_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="My Tasks ▾" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:ellipsize="end" android:maxLines="1"/>

        <!-- Refresh -->
        <TextView android:id="@+id/widget_refresh" android:layout_width="40dp" android:layout_height="40dp" android:text="↺" android:textColor="#BBFFFFFF" android:textSize="20sp" android:gravity="center"/>

        <!-- Add task — opens app at task creation -->
        <TextView android:id="@+id/widget_add" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:textColor="#BBFFFFFF" android:textSize="24sp" android:gravity="center"/>

        <!-- Settings — opens app -->
        <TextView android:id="@+id/widget_settings" android:layout_width="40dp" android:layout_height="40dp" android:text="⚙" android:textColor="#BBFFFFFF" android:textSize="16sp" android:gravity="center"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#44FFFFFF" android:layout_marginStart="10dp" android:layout_marginEnd="10dp"/>

    <!-- ── Task list (scrollable) ──────────────────────────────────────── -->
    <ListView android:id="@+id/widget_task_list" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:divider="@null" android:dividerHeight="0dp" android:scrollbars="none"/>

    <!-- Shown only when task list is empty -->
    <TextView android:id="@+id/widget_empty" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center" android:text="No tasks — tap + to add one" android:textColor="#66FFFFFF" android:textSize="13sp" android:visibility="gone"/>

</LinearLayout>