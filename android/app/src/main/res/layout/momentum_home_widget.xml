<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@drawable/widget_background">

     <!-- Header -->
     <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="12dp" android:paddingEnd="4dp" android:background="#12122B">

          <TextView android:id="@+id/widget_team_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Personal Tasks" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:ellipsize="end" android:maxLines="1"/>

          <TextView android:id="@+id/widget_add" android:layout_width="38dp" android:layout_height="38dp" android:text="+" android:textColor="#4A90E2" android:textSize="24sp" android:gravity="center" android:contentDescription="Add task"/>

          <TextView android:id="@+id/widget_refresh" android:layout_width="36dp" android:layout_height="36dp" android:text="↺" android:textColor="#777799" android:textSize="18sp" android:gravity="center" android:contentDescription="Refresh"/>
     </LinearLayout>

     <!-- Divider - use TextView instead of View (View banned in RemoteViews API 31+) -->
     <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#22224A" android:text=""/>

     <LinearLayout android:id="@+id/row0" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="8dp" android:visibility="gone">
          <TextView android:id="@+id/check0" android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:textSize="16sp"/>
          <TextView android:id="@+id/name0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="1" android:ellipsize="end" android:layout_marginStart="4dp"/>
     </LinearLayout>

     <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#11112A" android:text=""/>

     <LinearLayout android:id="@+id/row1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="8dp" android:visibility="gone">
          <TextView android:id="@+id/check1" android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:textSize="16sp"/>
          <TextView android:id="@+id/name1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="1" android:ellipsize="end" android:layout_marginStart="4dp"/>
     </LinearLayout>

     <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#11112A" android:text=""/>

     <LinearLayout android:id="@+id/row2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="8dp" android:visibility="gone">
          <TextView android:id="@+id/check2" android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:textSize="16sp"/>
          <TextView android:id="@+id/name2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="1" android:ellipsize="end" android:layout_marginStart="4dp"/>
     </LinearLayout>

     <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#11112A" android:text=""/>

     <LinearLayout android:id="@+id/row3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="8dp" android:visibility="gone">
          <TextView android:id="@+id/check3" android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:textSize="16sp"/>
          <TextView android:id="@+id/name3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="1" android:ellipsize="end" android:layout_marginStart="4dp"/>
     </LinearLayout>

     <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#11112A" android:text=""/>

     <LinearLayout android:id="@+id/row4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="10dp" android:paddingEnd="8dp" android:visibility="gone">
          <TextView android:id="@+id/check4" android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:textSize="16sp"/>
          <TextView android:id="@+id/name4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="1" android:ellipsize="end" android:layout_marginStart="4dp"/>
     </LinearLayout>

     <TextView android:id="@+id/widget_empty" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="5" android:gravity="center" android:text="No tasks — tap + to add one" android:textColor="#66FFFFFF" android:textSize="12sp" android:visibility="visible"/>

</LinearLayout>