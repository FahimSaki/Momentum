<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@drawable/widget_background">

     <!-- ─── Header ─── -->
     <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="12dp" android:paddingEnd="2dp" android:background="#12122B">

          <TextView android:id="@+id/widget_team_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Personal Tasks  ▾" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:ellipsize="end" android:maxLines="1"/>

          <!-- Add task -->
          <TextView android:id="@+id/widget_add" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:textColor="#4A90E2" android:textSize="24sp" android:gravity="center" android:contentDescription="Add task"/>

          <!-- Refresh -->
          <TextView android:id="@+id/widget_refresh" android:layout_width="38dp" android:layout_height="38dp" android:text="↺" android:textColor="#777799" android:textSize="18sp" android:gravity="center" android:contentDescription="Refresh"/>

     </LinearLayout>

     <!-- Hairline divider -->
     <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22224A"/>

     <!-- ─── Task list (RemoteViews ListView) ─── -->
     <ListView android:id="@+id/widget_task_list" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:divider="#22224A" android:dividerHeight="1dp" android:scrollbars="none" android:visibility="gone"/>

     <!-- ─── Empty state ─── -->
     <TextView android:id="@+id/widget_empty" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center" android:text="No tasks — tap + to add one" android:textColor="#66FFFFFF" android:textSize="12sp" android:visibility="visible"/>

</LinearLayout>