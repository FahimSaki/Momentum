<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="10dp">

    <!-- Circle checkbox — tapping this marks task complete (opens app) -->
    <TextView android:id="@+id/task_check" android:layout_width="32dp" android:layout_height="32dp" android:text="○" android:textColor="#888888" android:textSize="20sp" android:gravity="center"/>

    <!-- Task name -->
    <TextView android:id="@+id/task_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Task name" android:textColor="#FFFFFF" android:textSize="14sp" android:ellipsize="end" android:maxLines="1" android:layout_marginStart="6dp"/>

    <!-- Team label (shown when in a team context) -->
    <TextView android:id="@+id/task_team" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#66FFFFFF" android:textSize="11sp" android:maxLines="1" android:layout_marginStart="4dp" android:visibility="gone"/>

</LinearLayout>